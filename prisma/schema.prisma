// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Transaction {
  id            String   @id @default(uuid())
  order_id      String   @unique
  name          String
  email         String
  amount        Int
  message       String?
  status        String   @default("pending") // pending, settlement, cancel, expire
  snap_token    String?
  payment_type  String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  media_type    String?  // youtube, tiktok, tts
  media_url     String?
}

model Leaderboard {
  id         String   @id @default(uuid())
  name       String
  amount     Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}
